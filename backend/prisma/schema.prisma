generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email      String   @unique
  name       String
  password   String?
  provider   String?  @default("local")
  providerId String?  @unique
  role       String   @default("MEMBER")
  weeklyReportEnabled Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teams          TeamMember[]
  assignedTasks  Task[]
  focusSessions  FocusSession[]
  productivity   ProductivityLog[]
  subscription   Subscription?
  messages       Message[]
  alerts         Alert[]
  executionSignals ExecutionSignal[]
  focusStability   FocusStabilitySlot[]
  executionEvents  ExecutionEvent[]
  weeklyFocusReports WeeklyFocusReport[]
  estimationRecords  EstimationRecord[]
  estimationPatterns EstimationPattern[]
  gitHubConnection   GitHubConnection?
  googleCalendarConnection GoogleCalendarConnection?
  linkedPRs          LinkedPR[]
  effortNarratives   EffortNarrative[]
  aiDisplacements    AIDisplacementSummary[]
}

model Team {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())

  members      TeamMember[]
  projects     Project[]
  invitations  Invitation[]
}

model TeamMember {
  id       String @id @default(uuid())
  userId   String
  teamId   String
  teamRole String @default("member")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  teamId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team     Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tasks    Task[]
  messages Message[]
  sprints  Sprint[]
}

model Message {
  id        String   @id @default(uuid())
  content   String
  authorId  String
  projectId String
  createdAt DateTime @default(now())

  author  User    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Alert {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      String     @default("PENDING")
  phase       String     @default("allocation")
  projectId   String
  assigneeId  String?
  sprintId    String?
  dueDate     DateTime?
  priority    String     @default("medium")
  isStarred   Boolean    @default(false)
  isSample    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee      User?          @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  sprint        Sprint?        @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  focusSessions FocusSession[]
  executionSignals ExecutionSignal[]
  executionEvents ExecutionEvent[]
  dependencies    TaskDependency[] @relation("TaskDependencies")
  blocks          TaskDependency[] @relation("TaskBlocks")
  estimationRecord EstimationRecord?
  linkedPRs       LinkedPR[]
}

model FocusSession {
  id           String    @id @default(uuid())
  userId       String
  taskId       String
  startTime    DateTime  @default(now())
  endTime      DateTime?
  durationSecs Int       @default(0)
  interrupts   Int       @default(0)
  qualityScore Float?
  aiAssisted   Boolean   @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model ProductivityLog {
  id        String   @id @default(uuid())
  userId    String
  date      DateTime @default(now())
  metric    String
  value     Float
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                   String    @id @default(uuid())
  userId               String    @unique
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  plan                 String    @default("FREE")
  status               String    @default("ACTIVE")
  currentPeriodEnd     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExecutionSignal {
  id               String   @id @default(uuid())
  taskId           String
  userId           String
  effortDensity    Float
  resumeRate       Float
  progressVelocity String
  blockerRisk      Boolean
  computedAt       DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
}

model FocusStabilitySlot {
  id          String   @id @default(uuid())
  userId      String
  dayOfWeek   Int
  hourOfDay   Int
  focusScore  Float
  sampleCount Int      @default(0)
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayOfWeek, hourOfDay])
}

model ExecutionEvent {
  id          String   @id @default(uuid())
  taskId      String
  userId      String
  eventType   String   // e.g. 'FOCUS_START', 'FOCUS_PAUSE', 'FOCUS_STOP', 'STATUS_CHANGE', 'BLOCKER_DETECTED'
  metadata    String?  // JSON stringified metadata
  timestamp   DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TaskDependency {
  id          String   @id @default(uuid())
  taskId      String   // The task that is blocked
  blocksId    String   // The task that is blocking
  type        String   // 'BLOCKS', 'RELATES_TO'
  createdAt   DateTime @default(now())

  task   Task @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  blocks Task @relation("TaskBlocks", fields: [blocksId], references: [id], onDelete: Cascade)

  @@unique([taskId, blocksId])
}

model Invitation {
  id        String   @id @default(uuid())
  email     String
  teamId    String
  role      String   @default("MEMBER")
  token     String   @unique
  status    String   @default("PENDING") // PENDING, ACCEPTED, EXPIRED
  expiresAt DateTime
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model Sprint {
  id        String   @id @default(uuid())
  name      String
  startDate DateTime
  endDate   DateTime
  status    String   @default("PLANNED") // PLANNED, ACTIVE, COMPLETED
  projectId String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]
}

model WeeklyFocusReport {
  id             String   @id @default(uuid())
  userId         String
  weekLabel      String   // 'YYYY-WW'
  deepFocusHours Float    // sessions >= 25 min, interrupts <= 2
  sessionCount   Int
  avgSessionMins Float
  topFragmentor  String?  // plain-English cause, generated by worker
  bestWeekHours  Float?   // rolling 4-week personal best
  generatedAt    DateTime @default(now())
  
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, weekLabel])
}

model EstimationRecord {
  id              String   @id @default(uuid())
  userId          String
  taskId          String   @unique
  taskTitle       String
  predictedEffort String   // S | M | L
  actualHours     Float
  extractedKeywords String // space-separated list
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model EstimationPattern {
  id               String   @id @default(uuid())
  userId           String
  keyword          String   // e.g. "auth", "api", "refactor"
  predictedEffort  String   // The classification (e.g. "S")
  actualAvgHours   Float    // The average hours actually taken
  ratio            Float    // actualAvgHours / expectedBaseline
  sampleSize       Int
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, keyword, predictedEffort])
}

model GitHubConnection {
  id          String   @id @default(cuid())
  userId      String   @unique
  githubLogin String
  accessToken String
  scopes      String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LinkedPR {
  id          String    @id @default(cuid())
  taskId      String
  userId      String
  owner       String
  repo        String
  prNumber    Int
  prTitle     String?
  state       String    @default("open")
  openedAt    DateTime?
  mergedAt    DateTime?
  lastChecked DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  @@unique([taskId, owner, repo, prNumber])
}

// -----------------------------------------
// Deep Work Calendar Integrations (Feature 4)
// -----------------------------------------
model GoogleCalendarConnection {
  id           String    @id @default(cuid())
  userId       String    @unique
  googleEmail  String
  accessToken  String    // encrypted
  refreshToken String    // encrypted
  calendarId   String    @default("primary")
  lastSynced   DateTime?
  user         User      @relation(fields: [userId], references: [id])
}

model FocusCalendarEvent {
  id          String   @id @default(cuid())
  userId      String
  gcalEventId String?
  dayOfWeek   Int      // 0=Sun … 6=Sat
  startHour   Int
  endHour     Int
  createdAt   DateTime @default(now())
}

// -----------------------------------------
// Feature 5: Weekly Effort Narrative
// -----------------------------------------
model EffortNarrative {
  id          String    @id @default(cuid())
  userId      String
  weekLabel   String    // 'YYYY-WW'
  body        String    // generated prose; editable by engineer
  isEdited    Boolean   @default(false)
  shareToken  String?   @unique
  shareExpiry DateTime?
  generatedAt DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id])
  @@unique([userId, weekLabel])
}

// -----------------------------------------
// Feature 6: AI Time Displacement Tracker
// -----------------------------------------
model AIDisplacementSummary {
  id               String   @id @default(cuid())
  userId           String
  weekLabel        String
  aiHours          Float
  humanHours       Float
  aiTaskEfforts    String   // sqlite fallback for String[] (e.g. "S,M,L")
  humanTaskEfforts String   // sqlite fallback for String[]
  insightText      String   // pre-computed insight sentence
  updatedAt        DateTime @updatedAt
  
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, weekLabel])
}
